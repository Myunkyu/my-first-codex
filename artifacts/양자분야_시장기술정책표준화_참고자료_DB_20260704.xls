 <Worksheet ss:Name="00_README"><Table>
  <Column ss:Width="120"/><Column ss:Width="550"/>
  <Row ss:Height="28"><Cell ss:MergeAcross="1" ss:StyleID="Title"><Data ss:Type="String">양자 분야 시장·기술·정책·표준화 참고자료 DB</Data></Cell></Row>
  <Row ss:Height="38"><Cell ss:MergeAcross="1" ss:StyleID="Subtitle"><Data ss:Type="String">R1~R40 참고자료와 지속 모니터링 대상을 실무용 참조 DB로 정리함. 업데이트 기준일: 2026-07-04</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">파일 구성</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">01_참고자료_DB: 전체 참고자료 40종 / 02_분류별_요약: 분류와 우선순위 요약 / 03_우선순위_활용: 보고서 반영 원칙 / 04_지속_모니터링: 갱신 점검 대상 / 05_코드북: 컬럼 정의</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">활용 원칙</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부·국제표준·동료평가 자료는 핵심 근거로, 기업 로드맵과 컨설팅 전망은 보완 및 교차검증 자료로 활용함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">주의 사항</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">URL, 발행상태, 입법·표준의 확정 여부는 최종 보고서 발행 직전에 재확인하는 것을 권장함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">출처 구분</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">R1~R9는 사용자 제공 자료, R10~R40은 최신 공개자료 추가 조사 목록임.</Data></Cell></Row>
 </Table></Worksheet>
 <Worksheet ss:Name="01_참고자료_DB"><Table>
  <Column ss:Width="42"/><Column ss:Width="105"/><Column ss:Width="120"/><Column ss:Width="150"/><Column ss:Width="280"/><Column ss:Width="90"/><Column ss:Width="100"/><Column ss:Width="130"/><Column ss:Width="330"/><Column ss:Width="310"/><Column ss:Width="130"/><Column ss:Width="70"/><Column ss:Width="115"/><Column ss:Width="70"/>
  <Row ss:Height="36"><Cell ss:StyleID="Header"><Data ss:Type="String">ID</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">대분류</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">세부분류</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">발행기관</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">자료명</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">자료연도/기준</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">국가/권역</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">자료 성격</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">핵심 내용</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">주요 활용 목적</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">권장 활용 수준</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">우선순위</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">최신성/상태</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">URL</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R1</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">PQC 표준 승인</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST CSRC</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Post-Quantum Cryptography FIPS Approved</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2024</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 표준 승인</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">FIPS 203, FIPS 204, FIPS 205 승인 및 양자내성암호 전환 기준을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">PQC 표준체계와 전환 기준의 1차 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효·후속자료 존재</Data></Cell><Cell ss:HRef="https://csrc.nist.gov/news/2024/postquantum-cryptography-fips-approved" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R2</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 국가전략·예산</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">National Quantum Initiative</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Annual Report FY2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">FY2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 연례보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 국가양자이니셔티브의 연방 프로그램, 기관별 활동 및 예산자료를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 정책지원과 연구활동 규모의 연결 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효·2026 정책과 병행</Data></Cell><Cell ss:HRef="https://www.quantum.gov/wp-content/uploads/2024/12/NQI-Annual-Report-FY2025.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R3</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 전략 선언</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">European Commission</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">European Declaration on Quantum Technologies</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2023</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">EU</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책 선언</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 양자기술의 전략적 중요성과 유럽 양자 생태계 협력 방향을 선언함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 공동연구 및 생태계 협력 방향의 배경자료로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효·상위전략 구체화</Data></Cell><Cell ss:HRef="https://digital-strategy.ec.europa.eu/en/library/european-declaration-quantum-technologies" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R4</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 연구·산업 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Flagship</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Strategic Research and Industry Agenda 2030</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2030 목표</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">EU</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">연구·산업 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유럽 양자컴퓨팅·통신·센싱·기반기술의 연구 및 산업 로드맵을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술군별 연구방향과 산업화 과제 분류에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효·개정 모니터링</Data></Cell><Cell ss:HRef="https://qt.eu/about-quantum-flagship/strategic-research-and-industry-agenda-2030" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R5</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">영국 국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">UK Government</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">National Quantum Strategy</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">10년 전략</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">영국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">영국의 장기 양자기술 전략과 연구·혁신·산업화·인력 방향을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">영국 연구·산업화 및 인력정책의 기준자료로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효·실행정책 강화</Data></Cell><Cell ss:HRef="https://www.gov.uk/government/publications/national-quantum-strategy" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R6</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장·산업</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">글로벌 시장·채택</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">McKinsey</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Technology Monitor 2026: A Commercial Tipping Point</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장·산업 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자기술의 상업화 전환, 기업 채택, 투자 및 산업 생태계 변화를 분석함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장 전환과 기업 채택 신호를 설명하는 핵심 자료로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장전망 보조근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 핵심자료</Data></Cell><Cell ss:HRef="https://www.mckinsey.com/capabilities/mckinsey-technology/our-insights/mckinsey-quantum-technology-monitor-2026-a-commercial-tipping-point" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R7</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장·산업</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">장기 경제가치</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Boston Consulting Group</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Forecast for Quantum Computing Still Looks Bright</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2024</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장 전망 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">2040년 양자컴퓨팅 경제가치와 하드웨어·소프트웨어 시장 전망을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">장기 시장규모와 경제가치의 시나리오 비교에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장전망 보조근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효·전망 시나리오</Data></Cell><Cell ss:HRef="https://www.bcg.com/publications/2024/long-term-forecast-for-quantum-computing-still-looks-bright" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R8</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">초전도 양자컴퓨팅</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IBM Quantum</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Hardware and Roadmap</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026·2029 목표</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 기술 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">2026년 양자 이점과 2029년 오류정정 기반 대규모 양자컴퓨터 목표를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">하드웨어·오류정정·소프트웨어 연구수요 해석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 목표·검증 필요</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 로드맵</Data></Cell><Cell ss:HRef="https://www.ibm.com/quantum/hardware" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R9</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">이동통신 PQC 전환</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">GSMA</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Post-Quantum Cryptography Documents</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025~2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌 통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">산업 표준·실무 문서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">4G·5G 로밍, IoT, 이동통신망 및 비지상망의 양자안전 전환 문서를 제공함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">통신망 PQC 적용과 산업 전환 시사점 도출에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">산업 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">지속 갱신</Data></Cell><Cell ss:HRef="https://www.gsma.com/solutions-and-impact/technologies/security/post-quantum-cryptography-documents/" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R10</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장·산업</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">일본 양자 생태계</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">JETRO</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Japan Quantum Ecosystem Reports 2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">일본·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">산업·생태계 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">글로벌 시장전망과 일본의 연구역량, 소재·부품·제조 기반 및 공급망을 분석함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">일본의 산업·공급망 강점과 글로벌 생태계 비교에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">공공 산업정보 보조근거</Data></Cell><Cell ss:StyleID="Medium"><Data ss:Type="String">중간</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 보조자료</Data></Cell><Cell ss:HRef="https://www.jetro.go.jp/ext_images/en/invest/resource/pdf/QR_01.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R11</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장·산업</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">호주 생태계 현황</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Australian Government</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">State of Australian Quantum Report 2024</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2024</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">호주</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 산업현황 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가양자전략 이행, 연구·산업 생태계, 투자, 인력 및 과제를 종합함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가 생태계와 정책성과 비교에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Medium"><Data ss:Type="String">중간</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://www.industry.gov.au/publications/state-australian-quantum-report-2024" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R12</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 오류정정</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Google Quantum AI / Nature</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Error Correction Below the Surface Code Threshold</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2024</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 기술논문</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">코드 거리가 증가할수록 논리 오류가 감소하는 below-threshold 오류정정을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">초전도 방식의 오류정정 진전과 기술 성숙도 판단에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 핵심근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 완료</Data></Cell><Cell ss:HRef="https://www.nature.com/articles/s41586-024-08449-y" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R13</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동적 표면코드</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Nature Physics</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Demonstration of Dynamic Surface Codes</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 기술논문</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">하드웨어 연결성과 누설오류 제약을 완화하는 동적 표면코드 구현을 실증함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">오류정정 아키텍처의 다변화와 구현 가능성 평가에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 핵심근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 완료</Data></Cell><Cell ss:HRef="https://www.nature.com/articles/s41567-025-03070-w" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R14</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">독립 기술검증</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">DARPA</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Benchmarking Initiative</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2033 검증목표</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 기술검증 프로그램</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">산업적으로 유용한 양자컴퓨터 구현 가능성을 독립적·정량적으로 검증함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 기술로드맵의 실현 가능성을 보완 검증함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">진행 중</Data></Cell><Cell ss:HRef="https://www.darpa.mil/research/programs/quantum-benchmarking-initiative" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R15</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">통합 기술 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IEEE Standards Association</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Technologies for Emerging and Future Applications</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">최신 로드맵</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·표준 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자컴퓨팅·통신·소재·소자·측정을 상호의존적 기술체계로 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술 병목과 공급망을 통합적으로 분류하는 기준으로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국제 기술로드맵</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://ieeexplore.ieee.org/document/11244610/" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R16</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">이온트랩 양자컴퓨팅</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantinuum</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Accelerated Roadmap to Universal Fault-Tolerant Quantum Computing</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2030 목표</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·영국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 기술 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">2030년 범용 내결함성 양자컴퓨팅 목표를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">플랫폼별 기업 로드맵 비교에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 목표·검증 필요</Data></Cell><Cell ss:StyleID="Medium"><Data ss:Type="String">중간</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 로드맵</Data></Cell><Cell ss:HRef="https://www.quantinuum.com/press-releases/quantinuum-unveils-accelerated-roadmap-to-achieve-universal-fault-tolerant-quantum-computing-by-2030" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R17</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">투자·Starling 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IBM</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Investment and Starling Roadmap 2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026·2029 목표</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 투자·기술 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">투자계획과 2029년 내결함성 양자컴퓨터 목표를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술 로드맵과 제조·투자 확대 신호를 해석함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 목표·검증 필요</Data></Cell><Cell ss:StyleID="Medium"><Data ss:Type="String">중간</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업 발표</Data></Cell><Cell ss:HRef="https://www.ibm.com/quantum/blog/10-billion-investment-faq" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R18</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 상위전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">European Commission</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Europe Strategy</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">EU</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">상위 정책전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">연구혁신, 인프라, 생태계, 우주·이중용도, 인력의 5개 축을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU의 최신 정책방향과 산업·공급망 전략의 핵심 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 핵심정책</Data></Cell><Cell ss:HRef="https://digital-strategy.ec.europa.eu/en/library/quantum-europe-strategy" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R19</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 입법 준비</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">European Commission</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Future EU Quantum Act Call for Evidence</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026 예정</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">EU</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">입법 준비자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">산업 생산능력, 공급망 회복력 및 거버넌스 강화 방향을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">향후 EU 산업·공급망 정책의 선행 신호로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">입법 준비 1차 자료</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">입법 준비·미확정</Data></Cell><Cell ss:HRef="https://digital-strategy.ec.europa.eu/en/news/commission-invites-contributions-shape-future-eu-quantum-act" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R20</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 양자혁신 행정명령</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">The White House</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Executive Order 14413: Ushering in the Next Frontier of Quantum Innovation</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">대통령 행정명령</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 국가양자전략 갱신, 기반기술, 산업협력 및 국가안보 방향을 강화함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국의 최신 양자 정책변화를 해석하는 최우선 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 핵심정책</Data></Cell><Cell ss:HRef="https://www.whitehouse.gov/presidential-actions/2026/06/ushering-in-the-next-frontier-of-quantum-innovation/" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R21</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 연방 PQC 전환</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">The White House / OMB</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Executive Order 14412 and OMB M-26-15</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">행정명령·실행지침</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">연방기관의 PQC 책임자, 자산 우선순위화, 전환계획 및 조달체계를 규정함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">PQC가 표준 선정에서 실제 정부 시스템 전환 단계로 이동한 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 실행정책</Data></Cell><Cell ss:HRef="https://www.whitehouse.gov/presidential-actions/2026/06/securing-the-nation-against-advanced-cryptographic-attacks/" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R22</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 정책 성과평가</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">U.S. GAO</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Computing: Updating the National Strategy Could Promote U.S. Leadership</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 감사·평가 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">미국 양자컴퓨팅 전략의 목표, 성과지표, 자원 및 역할·책임체계 보완 필요성을 평가함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책 성과와 한계를 균형 있게 검토하는 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">독립 정부평가</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 평가자료</Data></Cell><Cell ss:HRef="https://www.gao.gov/products/gao-26-107759" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R23</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">한국 양자종합계획</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">과학기술정보통신부</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">제1차 양자종합계획</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">대한민국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">범정부 종합계획</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">2035년 양자칩 제조 경쟁력, 전문인력, 기업 생태계 및 글로벌 표준 리더십 목표를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국내 연구·산업·인력·표준화 전략의 핵심 기준으로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 국내정책</Data></Cell><Cell ss:HRef="https://www.msit.go.kr/eng/bbs/view.do?bbsSeqNo=42&amp;mId=4&amp;mPid=2&amp;nttSeqNo=1222&amp;sCode=eng" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R24</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">일본 혁신전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Japan Cabinet Office</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Integrated Innovation Strategy 2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">일본</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가 혁신전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 산업화 원년과 Quantum-Ready Japan 구현 방향을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">일본의 산업화·AI 융합·시장창출 전략 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://www8.cao.go.jp/cstp/tougosenryaku/togo2025_honbun_eiyaku.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R25</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">일본 양자 생태계</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Japan Cabinet Office</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Promotion Measures for the Development of a Quantum Ecosystem</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">일본</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">생태계 실행자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">수요기업, 공급망, 산학관 협력 및 사업화 관점의 생태계 실행방향을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">일본의 수요·공급 생태계와 소재·부품 공급망 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://www8.cao.go.jp/cstp/english/quantum/q_ecosys_outline_en.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R26</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">캐나다 미션 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Government of Canada</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">National Quantum Strategy Mission Roadmaps</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">캐나다</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가 미션 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">컴퓨팅·소프트웨어, 통신·PQC, 센싱의 3대 미션별 과제와 기회를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">세부 기술군별 국가 과제와 실행주체 비교에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://ised-isde.canada.ca/site/national-quantum-strategy/en/overview-canadas-national-quantum-strategy/national-quantum-strategy-roadmap-quantum-sensing" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R27</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">호주 국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Australian Government</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">National Quantum Strategy</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">현행 전략</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">호주</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">연구역량, 산업 성장, 인력, 국제협력 및 책임 있는 기술개발 방향을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">호주 국가전략과 이행성과의 연계 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Medium"><Data ss:Type="String">중간</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://www.industry.gov.au/publications/national-quantum-strategy" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R28</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">영국 조달·산업화</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">UK Government</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Leap Programme</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">영국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 실행프로그램</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">대규모 재정지원과 양자컴퓨터 개발·조달·배치 계획을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">영국 전략이 실제 조달과 산업 배치 단계로 전환되는 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 실행정책</Data></Cell><Cell ss:HRef="https://www.gov.uk/government/news/uks-quantum-leap-tohelp-beat-diseasedeliver-high-paid-jobs-and-strengthen-national-security-as-first-country-in-the-world-to-roll-out-quantum" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R29</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">영국 양자 표준 네트워크</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">UK Government</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">National Network for Quantum Standards</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">영국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화 정책</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 표준 개발, 국제협력 및 시험평가 기반을 강화하는 국가 네트워크를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준 선점과 산업경쟁력의 관계 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 표준정책</Data></Cell><Cell ss:HRef="https://www.gov.uk/government/news/worlds-first-national-network-for-quantum-standards-to-boost-uk-leadership-and-trade-in-groundbreaking-future-tech" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R30</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">HQC 백업 KEM</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST Selects HQC as Fifth Algorithm for Post-Quantum Encryption</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준 알고리즘 선정</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">ML-KEM을 보완하는 백업 KEM으로 HQC를 선정함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">PQC 알고리즘 포트폴리오 다변화 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화 진행</Data></Cell><Cell ss:HRef="https://www.nist.gov/news-events/news/2025/03/nist-selects-hqc-fifth-algorithm-post-quantum-encryption" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R31</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">KEM 구현지침</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST CSRC</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">SP 800-227: Recommendations for Key-Encapsulation Mechanisms</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">보안 구현지침</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">KEM의 정의, 구현, 운용 및 안전한 사용 권고를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">FIPS 203을 실제 프로토콜과 시스템에 적용하는 기준으로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최종 지침</Data></Cell><Cell ss:HRef="https://csrc.nist.gov/news/2025/nist-publishes-sp-800-227" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R32</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">암호 민첩성</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST CSRC</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">CSWP 39upd1: Considerations for Achieving Crypto Agility</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">백서·전환지침</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">알고리즘 교체와 암호체계 전환을 운영 중단 없이 수행하기 위한 암호 민첩성 전략을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">PQC 전환을 기술·운영·거버넌스 관점으로 확장하는 핵심 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 최종자료</Data></Cell><Cell ss:HRef="https://csrc.nist.gov/pubs/cswp/39/considerations-for-achieving-cryptographic-agility/final" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R33</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">추가 전자서명 후보</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST CSRC</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IR 8610: Additional Digital Signature Schemes Status Report</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">미국·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화 상태보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">추가 PQC 전자서명 후보군의 평가 현황을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">전자서명 표준의 향후 확장 방향 모니터링에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">평가 진행</Data></Cell><Cell ss:HRef="https://csrc.nist.gov/Projects/post-quantum-cryptography/publications" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R34</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU PQC 전환 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">European Commission</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Coordinated Implementation Roadmap for Transition to Post-Quantum Cryptography</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">EU</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">공동 이행 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">EU 회원국의 PQC 전환 일정, 우선순위 및 핵심 인프라 전환 방향을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국가·산업별 PQC 전환일정 비교의 핵심 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 실행 로드맵</Data></Cell><Cell ss:HRef="https://digital-strategy.ec.europa.eu/en/library/coordinated-implementation-roadmap-transition-post-quantum-cryptography" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R35</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">하이브리드 KEM</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">ETSI</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">TS 104 015: Hybrid Key Encapsulation Mechanisms</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">유럽·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술 표준</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기존 암호와 PQC의 보안성을 결합하는 하이브리드 KEM 프레임워크를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">브라우저·모바일·통신의 전환기 암호구조 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국제 표준근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">발행</Data></Cell><Cell ss:HRef="https://www.etsi.org/deliver/etsi_ts/104000_104099/104015/01.01.01_60/ts_104015v010101p.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R36</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Secure Element 영향</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">ETSI</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">TR 104 005: Impact of PQC on Secure Element Specifications</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">유럽·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">USIM, 보안칩, 임베디드 보안요소 규격에 PQC가 미치는 영향을 분석함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">통신·IoT·반도체 분야의 PQC 전환과 공급망 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국제 표준근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">발행</Data></Cell><Cell ss:HRef="https://www.etsi.org/deliver/etsi_tr/104000_104099/104005/01.02.01_60/tr_104005v010201p.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R37</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">QRNG 시험·인증</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">ETSI</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">TR 104 171: Quantum Random Number Generators</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">유럽·글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기술 보고서</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">QRNG의 평가·시험·인증 및 양자안전 인프라 내 역할을 다룸.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자소자·보안·시험인증 기술 분석에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국제 표준근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">발행</Data></Cell><Cell ss:HRef="https://www.etsi.org/deliver/etsi_tr/104100_104199/104171/01.01.01_60/tr_104171v010101p.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R38</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 전 분야 국제표준</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IEC/ISO JTC 3</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Strategic Business Plan</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2026</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국제표준화 전략계획</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자컴퓨팅·시뮬레이션, 측정, 소스·검출기, 통신 및 기반기술의 표준화 범위를 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 전 분야의 국제표준화 구조를 파악하는 핵심 기준으로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 국제표준 근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 표준전략</Data></Cell><Cell ss:HRef="https://assets.iec.ch/further_informations/49854/SBP_JTC%203_2026.05.pdf" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R39</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 네트워크</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">ITU-T</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Y.Sup98: Technical Considerations Towards Quantum Networks</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">글로벌</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">국제전기통신 기술자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자 네트워크 구성요소, QKD 네트워크 진화, 계층모델 및 표준화 로드맵을 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">양자통신·네트워크 표준과 기술진화 분석의 핵심 근거로 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 국제표준 근거</Data></Cell><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">발행</Data></Cell><Cell ss:HRef="https://www.itu.int/rec/dologin_pub.asp?id=T-REC-Y.Sup98-202511-I%21%21PDF-E&amp;lang=s&amp;type=items" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Center"><Data ss:Type="String">R40</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">PQC 마이그레이션 일정</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">UK NCSC</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Timelines for Migration to Post-Quantum Cryptography</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">2025</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">영국</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">정부 실무지침</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">조직의 PQC 전환 준비, 계획 및 구현 일정을 단계적으로 제시함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">기업·공공기관의 양자안전 전환 로드맵 비교에 활용함.</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">핵심 1차 공식근거</Data></Cell><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">유효</Data></Cell><Cell ss:HRef="https://www.ncsc.gov.uk/guidance/pqc-migration-timelines" ss:StyleID="Link"><Data ss:Type="String">원문 열기</Data></Cell></Row>
 </Table><AutoFilter x:Range="R1C1:R41C14" xmlns="urn:schemas-microsoft-com:office:excel"/><WorksheetOptions xmlns="urn:schemas-microsoft-com:office:excel"><FreezePanes/><FrozenNoSplit/><SplitHorizontal>1</SplitHorizontal><TopRowBottomPane>1</TopRowBottomPane><ActivePane>2</ActivePane></WorksheetOptions></Worksheet>
 <Worksheet ss:Name="02_분류별_요약"><Table><Column ss:Width="180"/><Column ss:Width="85"/><Column ss:Width="100"/>
  <Row><Cell ss:MergeAcross="2" ss:StyleID="Title"><Data ss:Type="String">분류별 요약</Data></Cell></Row>
  <Row><Cell ss:StyleID="Header"><Data ss:Type="String">대분류</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">건수</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">비중</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">시장·산업</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">4</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">10.0%</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">기술·로드맵</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">7</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">17.5%</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">정책·국가전략</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">14</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">35.0%</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">표준화·PQC·통신</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">15</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">37.5%</Data></Cell></Row>
  <Row/><Row><Cell ss:StyleID="Header"><Data ss:Type="String">우선순위</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">건수</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">비중</Data></Cell></Row>
  <Row><Cell ss:StyleID="Top"><Data ss:Type="String">최우선</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">12</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">30.0%</Data></Cell></Row>
  <Row><Cell ss:StyleID="High"><Data ss:Type="String">높음</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">23</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">57.5%</Data></Cell></Row>
  <Row><Cell ss:StyleID="Medium"><Data ss:Type="String">중간</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="Number">5</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">12.5%</Data></Cell></Row>
 </Table></Worksheet>
 <Worksheet ss:Name="03_우선순위_활용"><Table><Column ss:Width="170"/><Column ss:Width="190"/><Column ss:Width="510"/>
  <Row><Cell ss:MergeAcross="2" ss:StyleID="Title"><Data ss:Type="String">보고서 반영 우선순위 및 활용 체계</Data></Cell></Row>
  <Row><Cell ss:StyleID="Header"><Data ss:Type="String">구분</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">참고번호</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">활용 원칙</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">최우선 반영 자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">R6, R18, R20, R21, R23, R28, R32, R34, R38, R39</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장 전환, 최신 국가전략, PQC 실행정책, 국제표준화 변화를 핵심 해석에 우선 반영함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">기술 성숙도 검증 자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">R12, R13, R14, R15</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">동료평가 실험성과, 독립 벤치마킹 및 통합 로드맵으로 기업 발표의 실현 가능성을 검증함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">시장전망 교차검증 자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">R6, R7, R10, R11</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">컨설팅 전망과 정부·공공 생태계 보고서를 교차 활용하여 단일 전망 의존을 완화함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">국가전략 비교 자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">R2~R5, R18~R28</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">주요국의 정책목표, 산업화, 인력, 공급망 및 실행체계를 비교함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">PQC·양자통신 실행 자료</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">R1, R9, R21, R29~R40</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">알고리즘 표준에서 실제 시스템 전환, 암호 민첩성, 하이브리드 구조 및 통신망 적용까지 분석함.</Data></Cell></Row>
 </Table></Worksheet>
 <Worksheet ss:Name="04_지속_모니터링"><Table><Column ss:Width="180"/><Column ss:Width="150"/><Column ss:Width="360"/><Column ss:Width="90"/><Column ss:Width="130"/><Column ss:Width="80"/>
  <Row><Cell ss:MergeAcross="5" ss:StyleID="Title"><Data ss:Type="String">지속 모니터링 대상</Data></Cell></Row>
  <Row><Cell ss:StyleID="Header"><Data ss:Type="String">모니터링 대상</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">관리기관</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">주요 점검항목</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">권장 주기</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">관련 참고번호</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">URL</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">NIST PQC Publications</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">NIST CSRC</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">HQC 표준안, 추가 전자서명 후보, FIPS 개정, 암호 민첩성 지침</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">월 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R1, R30~R33</Data></Cell><Cell ss:HRef="https://csrc.nist.gov/Projects/post-quantum-cryptography/publications" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">EU Quantum Act</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">European Commission</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">입법안 제안·채택 여부, 산업·공급망·거버넌스 조항</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">분기 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R19</Data></Cell><Cell ss:HRef="https://digital-strategy.ec.europa.eu/en/news/commission-invites-contributions-shape-future-eu-quantum-act" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Flagship SRIA</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Quantum Flagship</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">SRIA 및 세부 로드맵 개정 결과</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">분기 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R4</Data></Cell><Cell ss:HRef="https://qt.eu/about-quantum-flagship/strategic-research-and-industry-agenda-2030" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">DARPA QBI</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">DARPA</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">Stage B 검증결과, Stage C 진입 기업·플랫폼·벤치마크</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">월 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R14</Data></Cell><Cell ss:HRef="https://www.darpa.mil/research/programs/quantum-benchmarking-initiative" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">주요 기업 기술 로드맵</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IBM·Google·Quantinuum</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">논리 큐비트, 오류정정, 게이트 규모 및 목표 달성 여부</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">분기 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R8, R12, R16, R17</Data></Cell><Cell ss:HRef="https://www.ibm.com/quantum/hardware" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">IEC/ISO JTC 3</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">IEC/ISO</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">용어, 측정, 벤치마킹, QRNG, 센싱 및 통신 표준 프로젝트</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">분기 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R38</Data></Cell><Cell ss:HRef="https://assets.iec.ch/further_informations/49854/SBP_JTC%203_2026.05.pdf" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">ITU-T 양자 네트워크</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">ITU-T</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">QKD-TLS, 위성 QKDN 및 양자 강화 네트워크 권고안</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">분기 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R39</Data></Cell><Cell ss:HRef="https://www.itu.int/rec/dologin_pub.asp?id=T-REC-Y.Sup98-202511-I%21%21PDF-E&amp;lang=s&amp;type=items" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
  <Row><Cell ss:StyleID="Body"><Data ss:Type="String">GSMA PQC Programme</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">GSMA</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">이동통신·IoT·로밍·위성망별 PQC 지침 및 적용사례</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">월 1회</Data></Cell><Cell ss:StyleID="Center"><Data ss:Type="String">R9</Data></Cell><Cell ss:HRef="https://www.gsma.com/solutions-and-impact/technologies/security/post-quantum-cryptography-documents/" ss:StyleID="Link"><Data ss:Type="String">열기</Data></Cell></Row>
 </Table></Worksheet>
 <Worksheet ss:Name="05_코드북"><Table><Column ss:Width="140"/><Column ss:Width="260"/><Column ss:Width="440"/>
  <Row><Cell ss:MergeAcross="2" ss:StyleID="Title"><Data ss:Type="String">코드북 및 관리 기준</Data></Cell></Row>
  <Row><Cell ss:StyleID="Header"><Data ss:Type="String">항목</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">정의</Data></Cell><Cell ss:StyleID="Header"><Data ss:Type="String">관리 기준</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">대분류</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">자료의 주된 활용 영역</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">시장·산업 / 기술·로드맵 / 정책·국가전략 / 표준화·PQC·통신의 4개로 관리함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">권장 활용 수준</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">보고서 근거로 사용할 때의 신뢰·활용 방식</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">공식 1차 근거, 동료평가, 기업 목표, 시장전망 보조근거 등으로 구분함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">우선순위</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">현재 보고서 반영의 중요도</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최우선 / 높음 / 중간으로 구분하며 정책·표준 갱신 시 재조정함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">최신성/상태</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">자료의 현재 상태</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최신 정책, 진행 중, 기업 로드맵, 입법 준비, 지속 갱신 등을 명시함.</Data></Cell></Row>
  <Row><Cell ss:StyleID="Label"><Data ss:Type="String">URL</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">공식 원문 링크</Data></Cell><Cell ss:StyleID="Body"><Data ss:Type="String">최종 보고서 발행 직전에 접근 가능 여부와 최신 개정일을 확인함.</Data></Cell></Row>
 </Table></Worksheet>
</Workbook>